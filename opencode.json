{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "mcp": {
    "next-devtools": {
      "type": "local",
      "command": ["bunx", "--bun", "next-devtools-mcp@latest"],
      "enabled": true
    },
    "shadcn": {
      "type": "local",
      "command": ["bunx", "--bun", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "ultracite": {
      "type": "local",
      "command": [
        "bunx",
        "--bun",
        "mcp-remote@latest",
        "https://docs.ultracite.ai/mcp"
      ],
      "enabled": true
    },
    "react-grab": {
      "type": "local",
      "command": ["bunx", "--bun", "-y", "@react-grab/mcp@latest", "--stdio"]
    },
    "better-auth": {
      "type": "remote",
      "url": "https://mcp.chonkie.ai/better-auth/better-auth-builder/mcp",
      "enabled": true
    }
  }
}
