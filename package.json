{
  "name": "kiban",
  "version": "0.0.1",
  "private": true,
  "description": "Kiban is a template for next js apps inspired by the t3 stack.",
  "keywords": [
    "nextjs",
    "template",
    "full-stack"
  ],
  "homepage": "https://kiban.codingcodax.dev",
  "bugs": {
    "url": "https://github.com/codingcodax/kiban/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/codingcodax/kiban"
  },
  "license": "MIT",
  "author": {
    "name": "Alexis Guzman",
    "url": "https://github.com/codingcodax"
  },
  "type": "module",
  "scripts": {
    "build": "next build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "portless kiban next dev --turbopack",
    "start": "next start",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "fix:unsafe": "ultracite fix --unsafe",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.0",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "better-auth": "^1.6.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "portless": "^0.14.0",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.10.2",
    "postcss": "^8",
    "react-grab": "^0.1.44",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "ultracite": "7.8.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=22.0.0"
  }
}
